{
  "tasks": {
    "dev": "deno run --allow-env --allow-read --allow-write scripts/generate-config.ts && deno run --allow-net --allow-read --allow-write --allow-env --allow-sys --allow-run main.ts",
    "build": "deno task build:all",
    "build:all": "bash build.sh",
    "test": "deno test --allow-net --allow-read --allow-write --allow-env",
    "npm:prepare": "deno run --allow-read --allow-write --allow-env --allow-run scripts/build-npm-package.ts",
    "npm:pack": "cd npm && npm pack",
    "checksums": "deno run --allow-read --allow-write scripts/build-checksums.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/cli": "jsr:@std/cli@1",
    "@std/path": "jsr:@std/path@1",
    "@std/yaml": "jsr:@std/yaml@1",
    "@std/crypto": "jsr:@std/crypto@1",
    "@std/encoding": "jsr:@std/encoding@1",
    "@std/http": "jsr:@std/http@1",
    "@std/fs": "jsr:@std/fs@1",
    "@cliffy/command": "jsr:@cliffy/command@^1.0.0",
    "@cliffy/prompt": "jsr:@cliffy/prompt@^1.0.0",
    "@cliffy/table": "jsr:@cliffy/table@^1.0.0"
  },
  "compilerOptions": {
    "lib": ["deno.window", "deno.unstable"]
  }
}
